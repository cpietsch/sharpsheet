{
  "name": "sharpsheet",
  "version": "0.1.6",
  "description": "fast spritesheet generator using sharp",
  "author": {
    "name": "Christopher Pietsch",
    "url": "https://chrispie.com"
  },
  "keywords": [
    "spritesheet",
    "sharp",
    "sprite",
    "fast"
  ],
  "homepage": "https://github.com/cpietsch/sharpsheet",
  "license": "ISC",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cpietsch/sharpsheet.git"
  },
  "bin": {
    "sharpsheet": "bin/sharpsheet.js"
  },
  "main": "dist/sharpsheet.js",
  "module": "dist/sharpsheet.mjs",
  "files": [
    "bin/*",
    "dist/*.js",
    "dist/*.mjs",
    "src/*.js"
  ],
  "type": "module",
  "scripts": {
    "build": "rollup -c",
    "watch": "rollup -c -w"
  },
  "engines": {
    "node": ">=20.3.0"
  },
  "dependencies": {
    "@mapbox/shelf-pack": "^3.2.0",
    "glob": "^13.0.6",
    "sharp": "^0.34.5",
    "yargs": "^18.0.0"
  },
  "devDependencies": {
    "@rollup/plugin-terser": "^0.4.4",
    "rollup": "^4.27.3"
  },
  "publishConfig": {
    "access": "public"
  }
}
